<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS configuration for PAC file hosting.
  - Registers .pac and .dat MIME types so IIS serves them correctly.
  - Disables all caching so iOS re-fetches on every request.
-->
<configuration>
  <system.webServer>

    <!-- MIME types for PAC / WPAD -->
    <staticContent>
      <remove fileExtension=".pac" />
      <mimeMap fileExtension=".pac" mimeType="application/x-ns-proxy-autoconfig" />
      <remove fileExtension=".dat" />
      <mimeMap fileExtension=".dat" mimeType="application/x-ns-proxy-autoconfig" />
    </staticContent>

    <!-- Anti-caching headers (critical for iOS) -->
    <httpProtocol>
      <customHeaders>
        <add name="Cache-Control" value="no-cache, no-store, must-revalidate, max-age=0" />
        <add name="Pragma"        value="no-cache" />
        <add name="Expires"       value="-1" />
      </customHeaders>
    </httpProtocol>

    <!-- Default documents -->
    <defaultDocument>
      <files>
        <clear />
        <add value="proxy.pac" />
        <add value="wpad.dat" />
      </files>
    </defaultDocument>

  </system.webServer>
</configuration>
